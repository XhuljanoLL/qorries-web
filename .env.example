# Copy this file to .env.local and fill in your real values.
# .env.local is ignored by git — never commit your actual credentials.

# ── EmailJS ────────────────────────────────────────────────────────────────────
# Sign up at https://www.emailjs.com (free tier is enough).
# 1. Add a Gmail (or other) service  →  copy the Service ID below.
# 2. Create an email template        →  copy the Template ID below.
# 3. Go to Account → API Keys        →  copy your Public Key below.
VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key

# Your name and email as they will appear in the received emails.
VITE_EMAILJS_TO_NAME=Your Name
VITE_EMAILJS_TO_EMAIL=youremail@gmail.com
